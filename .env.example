# Server
PORT=3001
DEV_HOST=127.0.0.1
DEV_FALLBACK_PORT=3101
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/bluewhale-crm

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=30d

# Frontend / Email
CLIENT_URL=http://localhost:5173
JOB_PORTAL_URL=http://localhost:5174
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Blue Whale Migration <noreply@example.com>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false

# Cloudinary
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=EAAG...
WHATSAPP_APP_ID=123456789012345
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
WHATSAPP_APP_SECRET=replace_with_meta_app_secret
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace_with_custom_verify_token
WHATSAPP_GRAPH_API_VERSION=v21.0

# Meta Lead Ads
META_LEAD_ADS_APP_ID=123456789012345
META_LEAD_ADS_APP_SECRET=replace_with_meta_app_secret
META_TOKENS_ENCRYPTION_KEY=replace_with_a_32_plus_char_secret_for_token_encryption
META_LEAD_ADS_BUSINESS_LOGIN_CONFIG_ID=123456789012345
META_LEAD_ADS_WEBHOOK_VERIFY_TOKEN=replace_with_meta_lead_ads_verify_token
META_LEAD_ADS_GRAPH_API_VERSION=v21.0
META_LEAD_ADS_WEBHOOK_CALLBACK_BASE_URL=https://your-api.example.com
META_LEAD_ADS_CRM_SOURCE_LABEL=Meta Lead Ads
META_LEAD_ADS_AUTO_CREATE_LEADS=true
META_LEAD_ADS_AUTO_ASSIGN_TO_OWNER=false
META_LEAD_ADS_AUTO_SYNC_ENABLED=true
META_LEAD_ADS_SYNC_INTERVAL_MINUTES=20
META_LEAD_ADS_POLL_LOOKBACK_MINUTES=30
META_LEAD_ADS_SYNC_FORMS_ON_CONNECT=true
META_LEAD_ADS_POLL_ENABLED=true
META_LEAD_ADS_POLL_CRON=*/20 * * * *
META_LEAD_ADS_POLL_RUN_ON_STARTUP=true
